{
  "version": "1.0.0",
  "description": "EasyFind 预设规则库",
  "presets": [
    {
      "id": "preset-taobao-price",
      "name": "淘宝高价商品筛选",
      "description": "筛选价格大于等于指定金额的商品",
      "domains": ["*.taobao.com", "*.tmall.com"],
      "targetSelector": ".item, .product, [class*='item']",
      "dataSelector": ".price, [class*='price']",
      "conditions": [{
        "operator": ">=",
        "value": "500"
      }],
      "actions": { "match": "highlight", "noMatch": "dim" },
      "category": "电商",
      "enabled": false
    },
    {
      "id": "preset-bilibili-duration",
      "name": "B站长视频筛选",
      "description": "筛选时长超过 1 小时的视频",
      "domains": ["*.bilibili.com"],
      "targetSelector": ".bili-video-card, [class*='video-card']",
      "dataSelector": ".bili-video-card__info--duration, [class*='duration']",
      "extractPattern": "(?:(\\d+):)?(\\d{1,2}):(\\d{2})",
      "conditions": [{
        "groupIndex": 1,
        "defaultValue": 0,
        "operator": ">=",
        "value": "1"
      }],
      "actions": { "match": "highlight", "noMatch": "none" },
      "category": "视频",
      "enabled": false
    },
    {
      "id": "preset-hide-ads",
      "name": "隐藏常见广告",
      "description": "隐藏页面中的广告元素",
      "domains": ["*"],
      "targetSelector": "[class*='ad-'], [id*='ad-'], .advertisement, .ads, [class*='sponsor'], [data-ad]",
      "conditions": [],
      "actions": { "match": "hide", "noMatch": "none" },
      "category": "广告过滤",
      "enabled": false
    },
    {
      "id": "preset-hide-sidebar",
      "name": "淡化侧边栏",
      "description": "淡化页面侧边栏内容",
      "domains": ["*"],
      "targetSelector": "aside, .sidebar, [class*='sidebar']",
      "conditions": [],
      "actions": { "match": "dim", "noMatch": "none" },
      "category": "广告过滤",
      "enabled": false
    },
    {
      "id": "preset-github-stars",
      "name": "GitHub高星项目",
      "description": "高亮显示星标数超过 1000 的项目",
      "domains": ["github.com"],
      "targetSelector": "[data-testid='repository-card'], .repo-list-item",
      "dataSelector": "[data-testid='starCount'], span[data-view-component='octicon'] + span",
      "conditions": [{
        "operator": ">=",
        "value": "1000"
      }],
      "actions": { "match": "highlight", "noMatch": "dim" },
      "category": "开发",
      "enabled": false
    },
    {
      "id": "preset-stackoverflow-answers",
      "name": "StackOverflow高赞回答",
      "description": "高亮显示赞数超过 10 的回答",
      "domains": ["stackoverflow.com", "*.stackoverflow.com"],
      "targetSelector": ".answer",
      "dataSelector": ".js-vote-count",
      "conditions": [{
        "operator": ">=",
        "value": "10"
      }],
      "actions": { "match": "highlight", "noMatch": "none" },
      "category": "开发",
      "enabled": false
    },
    {
      "id": "preset-hackernews-points",
      "name": "HackerNews高分帖子",
      "description": "高亮显示分数超过 100 的帖子",
      "domains": ["news.ycombinator.com"],
      "targetSelector": ".athing",
      "dataSelector": ".score",
      "extractPattern": "(\\d+) points",
      "conditions": [{
        "groupIndex": 1,
        "operator": ">=",
        "value": "100"
      }],
      "actions": { "match": "highlight", "noMatch": "dim" },
      "category": "资讯",
      "enabled": false
    }
  ],
  "categories": [
    { "id": "电商", "name": "电商平台", "icon": "shopping_cart" },
    { "id": "视频", "name": "视频网站", "icon": "play_circle" },
    { "id": "广告过滤", "name": "广告过滤", "icon": "block" },
    { "id": "开发", "name": "开发工具", "icon": "code" },
    { "id": "资讯", "name": "新闻资讯", "icon": "article" }
  ],
  "actionTypes": [
    { "value": "highlight", "label": "高亮", "description": "添加绿色边框和背景高亮显示" },
    { "value": "dim", "label": "淡化", "description": "降低透明度，使元素变暗" },
    { "value": "hide", "label": "隐藏", "description": "完全隐藏元素" },
    { "value": "none", "label": "无操作", "description": "不执行任何操作" }
  ]
}
